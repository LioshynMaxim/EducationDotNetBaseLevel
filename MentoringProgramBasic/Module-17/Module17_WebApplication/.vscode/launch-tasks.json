{
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Launch Web API",
        "type": "coreclr",
        "request": "launch",
        "preLaunchTask": "build",
        "program": "${workspaceFolder}/Module-17/Module17_WebApplication/bin/Debug/net10.0/Module17_WebApplication.dll",
        "args": [],
        "cwd": "${workspaceFolder}/Module-17/Module17_WebApplication",
        "stopAtEntry": false,
        "serverReadyAction": {
          "action": "openExternally",
          "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
        },
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        },
        "sourceFileMap": {
          "/Views": "${workspaceFolder}/Module-17/Module17_WebApplication/Views"
        }
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "build",
        "command": "dotnet",
        "type": "process",
        "args": [
          "build",
          "${workspaceFolder}/Module-17/Module17_WebApplication/Module17_WebApplication.csproj",
          "/property:GenerateFullPaths=true",
          "/consoleloggerparameters:NoSummary"
        ],
        "problemMatcher": "$msCompile"
      },
      {
        "label": "run",
        "command": "dotnet",
        "type": "process",
        "args": [
          "run",
          "--project",
          "${workspaceFolder}/Module-17/Module17_WebApplication/Module17_WebApplication.csproj"
        ],
        "problemMatcher": "$msCompile"
      },
      {
        "label": "watch",
        "command": "dotnet",
        "type": "process",
        "args": [
          "watch",
          "run",
          "--project",
          "${workspaceFolder}/Module-17/Module17_WebApplication/Module17_WebApplication.csproj"
        ],
        "problemMatcher": "$msCompile"
      }
    ]
  }
}
