@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Northwind Store</h1>
    <p class="lead">Explore our products and categories</p>
    
    <div class="row mt-5">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Categories</h5>
                    <p class="card-text">Browse our product categories</p>
                    <a href="@Url.Action("Index", "Categories")" class="btn btn-primary">View Categories</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Products</h5>
                    <p class="card-text">View our complete product catalog</p>
                    <a href="@Url.Action("Index", "Products")" class="btn btn-primary">View Products</a>
                </div>
            </div>
        </div>
    </div>
</div>

