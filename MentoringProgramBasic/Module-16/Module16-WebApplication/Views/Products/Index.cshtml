@model IEnumerable<Module16_WebApplication.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Products</h1>
        <a asp-action="Create" class="btn btn-primary">Create New Product</a>
    </div>
    
    @if (ViewBag.MaxProducts > 0)
    {
        <div class="alert alert-info">
            Showing first @ViewBag.MaxProducts of @ViewBag.TotalProducts products (as configured in settings)
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Showing all @ViewBag.TotalProducts products
        </div>
    }
    
    <hr />
    
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Supplier</th>
                    <th>Quantity Per Unit</th>
                    <th>Unit Price</th>
                    <th>Units In Stock</th>
                    <th>Units On Order</th>
                    <th>Reorder Level</th>
                    <th>Discontinued</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.ProductID</td>
                        <td>@product.ProductName</td>
                        <td>@(product.Category?.CategoryName ?? "N/A")</td>
                        <td>@(product.Supplier?.CompanyName ?? "N/A")</td>
                        <td>@product.QuantityPerUnit</td>
                        <td>@product.UnitPrice?.ToString("C")</td>
                        <td>@product.UnitsInStock</td>
                        <td>@product.UnitsOnOrder</td>
                        <td>@product.ReorderLevel</td>
                        <td>
                            @if (product.Discontinued)
                            {
                                <span class="badge bg-danger">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-success">No</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@product.ProductID" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Details" asp-route-id="@product.ProductID" class="btn btn-sm btn-info">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="mt-3">
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Back to Home</a>
    </div>
</div>
